# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas Settings
# Replace with your MongoDB Atlas cluster details
# Format: cluster0.xxxxx.mongodb.net (get this from MongoDB Atlas > Connect > Connect your application)
MONGO_URI=mongodb+srv://bhavesh:bhavesh%4012@tripdb.ezjlcbd.mongodb.net/tripplanner?retryWrites=true&w=majority&appName=tripdb
MONGO_PORT=27017

# MongoDB Atlas database user credentials
# Create a database user in MongoDB Atlas (not your Atlas account email)

MONGO_AUTH_SOURCE=admin

# Database name
MONGO_DB_NAME=trip_db

# Connection timeouts (in milliseconds)
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=5000

# Connection pooling
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10

# Retry settings
MONGO_RETRY_WRITES=true
MONGO_RETRY_READS=true

# SSL/TLS settings (required for MongoDB Atlas)
MONGO_SSL=true
MONGO_TLS_ALLOW_INVALID_CERTIFICATES=false

# JWT Settings
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Pagination
PAGE_SIZE=10

# CORS Settings
CORS_ALLOW_ALL=1


# Email (Gmail SMTP)
# Use an App Password (not your normal Gmail password)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=tripzenai909@gmail.com
EMAIL_HOST_PASSWORD=zaab fnka ucte rtpg
EMAIL_FROM_DEFAULT=tripzenai909@gmail.com

# Logging
LOG_LEVEL=INFO